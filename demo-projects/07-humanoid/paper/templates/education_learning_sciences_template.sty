% Three-row table macro using the requested exemplar Table 2 column layout:
% p{2cm} p{0.9cm} p{0.9cm} p{1.9cm} p{1.9cm} p{1.9cm} p{2cm} p{1.6cm}
\newcommand{\sectiontable}[2]{%
\begin{center}
\captionsetup{type=table}
\captionof{table}{#1}
\small
\resizebox{\linewidth}{!}{%
\begin{tabular}{>{\raggedright\arraybackslash}p{2cm}
                >{\raggedright\arraybackslash}p{0.9cm}
                >{\raggedright\arraybackslash}p{0.9cm}
                >{\raggedright\arraybackslash}p{1.9cm}
                >{\raggedright\arraybackslash}p{1.9cm}
                >{\raggedright\arraybackslash}p{1.9cm}
                >{\raggedright\arraybackslash}p{2cm}
                >{\raggedright\arraybackslash}p{1.6cm}}
\toprule
\textbf{Item} & \textbf{Ref} & \textbf{Step} & \textbf{Input} & \textbf{Action} & \textbf{Output} & \textbf{Check} & \textbf{Status} \\
\midrule
#2
\bottomrule
\end{tabular}}
\end{center}}

